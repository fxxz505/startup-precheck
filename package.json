{
  "name": "startup-precheck",
  "version": "1.0.0",
  "description": "A local preflight checker for development projects.",
  "type": "module",
  "keywords": ["cli", "precheck", "startup", "diagnostics", "developer-tools"],
  "license": "MIT",
  "bin": {
    "precheck": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/index.js scan .",
    "dev": "tsx src/cli/index.ts scan .",
    "link:global": "npm run build && npm link",
    "test": "node --test dist/tests/**/*.test.js",
    "test:dev": "tsx --test src/tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
